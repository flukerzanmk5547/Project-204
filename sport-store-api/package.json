{
  "name": "sport-store-api",
  "version": "1.0.0",
  "type": "module",
  "description": "SportGear Thailand E-commerce API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:uat": "NODE_ENV=uat tsx watch src/index.ts",
    "dev:uat:auto": "NODE_ENV=uat UAT_AUTO_CONFIRM_PAYMENT=true tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:uat": "tsx scripts/seed-uat.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@evex/linejs": "npm:@jsr/evex__linejs",
    "@fastify/cors": "^11",
    "@fastify/helmet": "^13",
    "@fastify/rate-limit": "^10",
    "@supabase/supabase-js": "^2",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^16",
    "fastify": "^5",
    "pino-pretty": "^13.1.3",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsx": "^4",
    "@types/node": "^22"
  }
}
